# Go auth sidecar Dockerfile, resurrected for the parity harness.
#
# The production `images/sidecar/Dockerfile` was replaced with the
# Rust build in PR #63. The Go sources still live at
# `images/sidecar/main.go` (kept until phase 6 per the migration
# plan). This Dockerfile rebuilds the Go binary from those sources
# so the harness can run both sidecars side-by-side.
#
# Build context MUST be the repo root because this file COPYs
# files from `images/sidecar/` which lives outside the parity
# harness directory.

FROM golang:1.22-alpine AS builder
WORKDIR /build
COPY images/sidecar/main.go ./
COPY images/sidecar/main_test.go ./
COPY images/sidecar/go.mod ./
COPY images/sidecar/go.sum ./
RUN go build -o auth-sidecar .

FROM scratch
COPY --from=builder /build/auth-sidecar /auth-sidecar
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
ENTRYPOINT ["/auth-sidecar"]

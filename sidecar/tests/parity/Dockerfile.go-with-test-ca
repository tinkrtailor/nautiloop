# Go auth sidecar with the parity harness test CA appended to the
# system trust store.
#
# The Go sidecar reads /etc/ssl/certs/ca-certificates.crt via
# crypto/x509.SystemCertPool() on Linux. We append our test CA to
# that file so Go's http.Client accepts the mock service TLS
# certificates (which are signed by the test CA) without
# introducing a production-reachable trust path.
#
# Build context MUST be the repo root (see Dockerfile.go-sidecar).

FROM golang:1.22-alpine AS builder
WORKDIR /build
COPY images/sidecar/main.go ./
COPY images/sidecar/main_test.go ./
COPY images/sidecar/go.mod ./
COPY images/sidecar/go.sum ./
RUN go build -o auth-sidecar .

FROM alpine:3.20 AS ca-builder
RUN apk add --no-cache ca-certificates
COPY sidecar/tests/parity/fixtures/test-ca/ca.pem /tmp/test-ca.pem
RUN cat /tmp/test-ca.pem >> /etc/ssl/certs/ca-certificates.crt

FROM scratch
COPY --from=builder /build/auth-sidecar /auth-sidecar
COPY --from=ca-builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
ENTRYPOINT ["/auth-sidecar"]
